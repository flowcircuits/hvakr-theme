        "editorBracketHighlight.foreground4": "#1c6e42",
        "editorBracketHighlight.foreground5": "#866103",
        "editorBracketHighlight.foreground6": "#cd4246",

        "editorError.foreground": "#cd4246",
        "editorWarning.foreground": "#d1980b",
